{
  "Demo": {
    "SlowQueryThresholdMs": 500
  },

  "Providers": {
    "PostgreSql": {
      "ConnectionString": "Host=localhost;Port=5432;Database=atlas_demo;Username=postgres;Password=postgres;"
    },
    "SqlServer": {
      "ConnectionString": "Server=localhost,1433;Database=atlas_demo;User Id=sa;Password=Your_password123;TrustServerCertificate=True;"
    },
    "MySql": {
      "ConnectionString": "Server=localhost;Port=3306;Database=atlas_demo;User=root;Password=root;"
    }
  },

  "Atlas": {
    "Database": {
      "Provider": "PostgreSql",
      "ConnectionString": "",
      "CommandTimeoutSeconds": 30,
      "EnableSensitiveDataLogging": true,
      "EnableDetailedErrors": true,
      "Retry": {
        "Enabled": true,
        "MaxRetryCount": 3,
        "MaxRetryDelaySeconds": 30
      },
      "Pool": {
        "Enabled": true,
        "MinSize": 1,
        "MaxSize": 10
      },
      "Migration": {
        "AutoMigrateOnStartup": true,
        "SeedDataOnStartup": false
      }
    }
  }
}
